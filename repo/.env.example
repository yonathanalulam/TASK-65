# Culinary Coach Workstation — Environment Configuration
# Copy to .env and set values before first run.

# REQUIRED: Bootstrap admin password (used only on first run to create admin user)
# Must meet password policy: 12+ chars, uppercase, lowercase, digit, special char
APP_BOOTSTRAP_ADMIN_PASSWORD=

# REQUIRED: Encryption key for MFA TOTP secrets (32+ characters)
# Generate with: openssl rand -base64 32
MFA_ENCRYPTION_KEY=

# Database connection (defaults match docker-compose.yml)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/culinary_coach?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=cc_user
SPRING_DATASOURCE_PASSWORD=cc_password

# Server port
SERVER_PORT=8080
